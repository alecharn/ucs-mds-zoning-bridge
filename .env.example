# Path to this .env file (used by the script to locate it)
MAIN_ENV_PATH=/absolute/path/to/.env

# Intersight API credentials
INTERSIGHT_KEY_ID=your-intersight-key-id
INTERSIGHT_SECRET_KEY_PATH=/absolute/path/to/intersight_secret_key.pem

# MDS Switch A credentials
MDS_IP_ADDRESS_A=192.0.2.1
MDS_USERNAME_A=admin
MDS_PASSWORD_A=changeme

# MDS Switch B credentials
MDS_IP_ADDRESS_B=192.0.2.2
MDS_USERNAME_B=admin
MDS_PASSWORD_B=changeme
